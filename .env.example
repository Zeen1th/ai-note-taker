# Local LLM (Ollama) — used for notes generation and chat.
OLLAMA_MODEL=qwen3:14b
OLLAMA_HOST=http://localhost:11434

# WhisperX transcription model: tiny / base / small / medium / large-v3
WHISPER_MODEL=base

# Where WhisperX runs. Keep on CPU so the GPU is free for the LLM (12GB VRAM plan).
# Use device=cuda + compute_type=float16 only if you have spare VRAM.
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
# CPU threads for transcription (faster-whisper default is only 4).
# Set near your physical core count for a big CPU speedup.
WHISPER_THREADS=16
WHISPER_BATCH_SIZE=16
# Diarization (speaker-splitting) model. pyannote-audio 4.x requires community-1.
# Accept its terms (instant) at the HF model page so HF_TOKEN can download it.
DIARIZE_MODEL=pyannote/speaker-diarization-community-1

# Hugging Face token for the pyannote speaker-diarization model.
# Create a free account, accept the terms for pyannote/speaker-diarization-3.1,
# then create an access token: https://huggingface.co/settings/tokens
HF_TOKEN=
