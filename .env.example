# Local LLM (Ollama) — used for notes generation and chat.
OLLAMA_MODEL=qwen3:14b
OLLAMA_HOST=http://localhost:11434
# Context window. 8192 keeps qwen3 small & 100% on GPU (fast). Ollama's default
# 40960 bloats VRAM and spills to CPU. Raise for very long transcripts.
OLLAMA_NUM_CTX=8192
# qwen3 reasons before answering (slow, then discarded). true = re-enable.
OLLAMA_THINK=false

# WhisperX transcription model: tiny / base / small / medium / large-v3
#   large-v3-turbo = multilingual (~99 langs) + fast (good default on a GPU).
#   distil-large-v3 = English-only, fastest.
WHISPER_MODEL=base
# Language: empty = auto-detect per recording. Set e.g. "en"/"ar" to force one.
# (Note: distil-large-v3 is English-only; use a multilingual model for others.)
WHISPER_LANGUAGE=

# Where WhisperX runs.
#   cpu  + compute_type=int8     -> leaves the GPU free for the LLM (12GB plan)
#   cuda + compute_type=float16  -> much faster, but shares VRAM with Ollama.
# GPU needs the CUDA build of PyTorch (see README). If cuda is set but
# unavailable, the app warns and falls back to CPU automatically.
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
# CPU threads for transcription (faster-whisper default is only 4).
# Set near your physical core count for a big CPU speedup.
WHISPER_THREADS=16
WHISPER_BATCH_SIZE=16
# Diarization (speaker-splitting) model. pyannote-audio 4.x requires community-1.
# Accept its terms (instant) at the HF model page so HF_TOKEN can download it.
DIARIZE_MODEL=pyannote/speaker-diarization-community-1

# Hugging Face token for the pyannote speaker-diarization model.
# Create a free account, accept the terms for pyannote/speaker-diarization-3.1,
# then create an access token: https://huggingface.co/settings/tokens
HF_TOKEN=
